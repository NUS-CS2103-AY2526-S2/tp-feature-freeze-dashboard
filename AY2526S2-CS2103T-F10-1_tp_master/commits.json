{"authorDailyContributionsMap":{"verudex":[{"date":"2026-04-11T00:00:00","commitResults":[{"hash":"1e7e043da4538420c33595583626f99788a5bca9","isMergeCommit":false,"messageTitle":"Enlarge model diagrams to fix rendering issues on Developer Guide","messageBody":"- Increase ModelClassDiagram display width from 650px to 800px\n- Increase BetterModelClassDiagram display width from 650px to 700px\n- Upgrade PlantUML scale from 1.2 to 1.5 for both diagrams\n\nThis improves diagram visibility and clarity while ensuring the right\nedge is not cut off when rendered on the Jekyll website. Higher scale\nproduces crisper diagram exports at the larger display widths.\n","fileTypesAndContributionMap":{"docs":{"insertions":6,"deletions":2}}},{"hash":"eb210103bd3794c8e3877440c84cb66937fc5681","isMergeCommit":false,"messageTitle":"Removed extra maxMessageSize fields from UML diagrams","messageBody":"","fileTypesAndContributionMap":{"docs":{"insertions":0,"deletions":2}}}]},{"date":"2026-04-12T00:00:00","commitResults":[{"hash":"a7562cb4247679bb0c9656d4298c8a50594436c5","isMergeCommit":false,"messageTitle":"Add phone and email constraints for add/edit commands in UG","messageBody":"- Add explicit phone constraints: digits only, 3-15 digits\n- Add explicit email constraints matching app validation logic\n- Clarify that the same constraints apply to edit command inputs\n","fileTypesAndContributionMap":{"docs":{"insertions":17,"deletions":0}}}]},{"date":"2026-04-13T00:00:00","commitResults":[{"hash":"3eae75fda67862ac1262da89bb2b95bd44371686","isMergeCommit":false,"messageTitle":"Add address constraints and tag field constraints","messageBody":"This change updates the User Guide to explicitly document address constraints for both add and edit commands. The guide now states that addresses must be 1-200 characters long, cannot be blank after trimming, and may contain only alphanumeric characters, single spaces between words, and the special characters #, ., ,, (, ), , and -. It also adds clearer valid and invalid examples so users can understand accepted formats without trial and error.\n\nThis change also improves how allergy and condition constraints are presented by splitting them into separate sections for al/ and mc/. Each section now documents its own length limit and formatting rules, with dedicated valid and invalid examples.\n\nIn addition, the address validation error message has been revised to match the documented behavior more closely, including the 1-200 character limit, non-blank requirement, single-space rule, and the allowed special-character set including backslash.\n","fileTypesAndContributionMap":{"functional-code":{"insertions":3,"deletions":2},"docs":{"insertions":14,"deletions":7}}},{"hash":"6d733e6ffc58d472cbdd9e9625bcdcdce4e3be46","isMergeCommit":false,"messageTitle":"Clarify separator rules in name validation and docs","messageBody":"Update name-related constraints to accurately reflect current validation behavior. The name error message now explains that names must be 1 to 100 characters, start and end with an alphanumeric character, and use only single separators between alphanumeric parts (space, hyphen, apostrophe, or comma with optional one following space).\n\nUpdate the User Guide to match the actual rules by documenting that separators are only allowed between alphanumeric parts and cannot be consecutive. Add explicit invalid examples, including patterns like asdj- -sads, to prevent confusion.\n\nAdd/extend name validation tests to cover leading separator, trailing separator, and consecutive separator edge cases so this behavior is clearly enforced and protected against regressions.\n","fileTypesAndContributionMap":{"functional-code":{"insertions":6,"deletions":5},"docs":{"insertions":6,"deletions":1},"test-code":{"insertions":4,"deletions":0}}},{"hash":"e72c9c8beb3f37146746eaf4b70b982c045f8660","isMergeCommit":true,"messageTitle":"Merge pull request #270 from alieron/fix/offline-help","messageBody":"Resolve offline help conflict","fileTypesAndContributionMap":{}},{"hash":"521bd87a495d58b2232e6ac0348b27a8e6e6500e","isMergeCommit":false,"messageTitle":"Update disclaimer for name field in add and edit command in UG","messageBody":"","fileTypesAndContributionMap":{"docs":{"insertions":1,"deletions":1}}}]},{"date":"2026-04-14T00:00:00","commitResults":[{"hash":"f358c9a860132ceac1739e7f5615280c5a82d0d5","isMergeCommit":false,"messageTitle":"Add PPP for Jx and Kenneth and fix spelling error in Cavan\u0027s PPP","messageBody":"","fileTypesAndContributionMap":{"docs":{"insertions":86,"deletions":1}}},{"hash":"940a8b25af7bb889bfd12c24d7db3e69ae2e3f6b","isMergeCommit":true,"messageTitle":"Merge pull request #299 from alieron/fix/docs","messageBody":"Fix minor issues in UG and DG","fileTypesAndContributionMap":{}}]}],"KenOKK3003":[{"date":"2026-04-12T00:00:00","commitResults":[{"hash":"216572feeeafc1f8d289cd0646b4dac60a7487c7","isMergeCommit":false,"messageTitle":"Refactor msgs from address to patient book","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":4,"deletions":4}}},{"hash":"d04fcc094efb8365388d0fb72f95c2920f52bd1e","isMergeCommit":false,"messageTitle":"Refactor exit msg to Doctor Who","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":1,"deletions":1}}},{"hash":"ac45c1f500d299e87ca346226eff01b58d8678d0","isMergeCommit":false,"messageTitle":"Replace sample NRIC in UG","messageBody":"","fileTypesAndContributionMap":{"docs":{"insertions":5,"deletions":5}}},{"hash":"5df0fe2f58618af6e8e01968589ed6a8f064a95a","isMergeCommit":false,"messageTitle":"Remove space from Doctor Who msg","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":1,"deletions":1}}}]},{"date":"2026-04-13T00:00:00","commitResults":[{"hash":"3bdfda2a9be2e61af8f74930226c0bbdf7488347","isMergeCommit":false,"messageTitle":"Replace help screenshot","messageBody":"","fileTypesAndContributionMap":{"docs":{"insertions":1,"deletions":1}}},{"ha