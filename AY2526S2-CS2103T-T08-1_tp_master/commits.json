itResults":[{"hash":"81f0a1483da354663d48c45e75cf38792c62f203","isMergeCommit":false,"messageTitle":"docs: Fix note clear-oldest prefix from c/ to co/ in UG","messageBody":"The note \u0027Remove first N notes\u0027 command uses the co/ prefix\n(PREFIX_CLEAR_OLDEST) but the UG and notes page documented it as c/.\nThis fixes the inconsistency between UG and the help window.\n\nFixes #373\n","fileTypesAndContributionMap":{"docs":{"insertions":5,"deletions":5}}},{"hash":"d5f8cd574d953968d3191110204242b49ab2f6f3","isMergeCommit":false,"messageTitle":"docs: Add lc/ prefix to find command documentation","messageBody":"The find command parser supports lc/ (last contacted) filtering\nbut this was not documented in the find-contacts page or the\nhelp window MESSAGE_USAGE.\n\nFixes #374\n","fileTypesAndContributionMap":{"functional-code":{"insertions":2,"deletions":0},"docs":{"insertions":2,"deletions":2}}},{"hash":"1225b0253e0357567450a5c279061102b80c12dc","isMergeCommit":false,"messageTitle":"docs: Add lc/ to find command summary table","messageBody":"The find command supports lc/ (last contacted) filtering but\nthe command summary table at the end of the UG omitted it.\n\nFixes #340\n","fileTypesAndContributionMap":{"docs":{"insertions":1,"deletions":1}}},{"hash":"48a8a3305646f2f775397500f9f3c045706ed6b0","isMergeCommit":false,"messageTitle":"docs: Add command format for find and sort in UG","messageBody":"The add and edit sections include explicit Format lines but\nfind and sort did not. Added the Format lines for consistency.\n\nFixes #372\n","fileTypesAndContributionMap":{"docs":{"insertions":6,"deletions":0}}},{"hash":"e20d84481c3b178a7f0ef275db961c13d5714f4e","isMergeCommit":false,"messageTitle":"docs: Fix singular/plural in UC5 and UC6","messageBody":"The headers use \u0027criterion\u0027 (singular) but the MSS steps used\n\u0027criteria\u0027 (plural). Changed MSS to use \u0027criterion\u0027 consistently.\n\nFixes #350\n","fileTypesAndContributionMap":{"docs":{"insertions":4,"deletions":4}}},{"hash":"a5ede40c774b31615068ac895fae004df90d6729","isMergeCommit":false,"messageTitle":"docs: Document limitations of similar-name detection","messageBody":"Added a note clarifying that similar contact detection uses\nexact matching only. Names like \u0027John Doe\u0027 and \u0027John Doe Sr.\u0027\nare not detected as similar.\n\nFixes #354\n","fileTypesAndContributionMap":{"docs":{"insertions":5,"deletions":0}}}]},{"date":"2026-04-12T00:00:00","commitResults":[{"hash":"eebca9997cfa8e9767d5f2a684da46dfcdea6f2d","isMergeCommit":true,"messageTitle":"Merge pull request #381 from p12010304/fix-note-prefix-typo","messageBody":"docs: Fix note clear-oldest prefix from c/ to co/","fileTypesAndContributionMap":{}},{"hash":"b06c63b78cef488b9aea2b558e4c1b4a51c9467b","isMergeCommit":true,"messageTitle":"Merge pull request #382 from p12010304/fix-find-lc-docs","messageBody":"docs: Add lc/ prefix to find command documentation","fileTypesAndContributionMap":{}},{"hash":"8c9b0d5c3844526c0998340d042c757a1f5abbc6","isMergeCommit":true,"messageTitle":"Merge pull request #383 from p12010304/fix-find-summary-lc","messageBody":"docs: Add lc/ to find command summary table","fileTypesAndContributionMap":{}},{"hash":"e4ba2cb92683324b98ac8689a716aa6029d38966","isMergeCommit":true,"messageTitle":"Merge pull request #385 from p12010304/fix-dg-uc-wording","messageBody":"docs: Fix singular/plural in UC5 and UC6","fileTypesAndContributionMap":{}},{"hash":"43ff2daadd6cf2bc56ddbe4b5bffb90f07a43cd0","isMergeCommit":false,"messageTitle":"Remove \u0027Image to be added\u0027 placeholder in view files section","messageBody":"The \u0027Viewing available files\u0027 section had a placeholder text\n\u0027Image to be added\u0027 that was displayed in the rendered User Guide.\nRemove it to clean up the documentation.\n\nFixes #351\n","fileTypesAndContributionMap":{"docs":{"insertions":0,"deletions":2}}},{"hash":"cec8b3f660b8d74c43d21bb8f00ce21136c765ea","isMergeCommit":false,"messageTitle":"Include sort criteria in sort command feedback message (#396)","messageBody":"* Include sort criteria in sort command feedback message\n\nThe sort command previously showed \u0027Sorted X contacts.\u0027 without\nspecifying the criteria used. Add getDescription() to comparator\nhierarchy so the message now shows the criteria, e.g.\n\u0027Sorted 11 contacts by name (ascending).\u0027\n\nFixes #371\n\n* Add tests for getDescription() in comparator hierarchy\n\nCover the new getDescription() and getSingleDescription() methods\nwith tests for identity (default order), single field, and\nmulti-field chained comparators including tag comparators.","fileTypesAndContributionMap":{"functional-code":{"insertions":34,"deletions":2},"test-code":{"insertions":16,"deletions":0}}},{"hash":"ea04d693e1ce6b8c5ced24b9c9d8e722acb28942","isMergeCommit":false,"messageTitle":"Clarify phone error message for country code numbers (#397)","messageBody":"The error message previously said \u00275-15 digits long\u0027 which did not\ndistinguish between numbers with and without a country code prefix.\nNumbers starting with \u0027+\u0027 require 8-15 digits, while others require\n5-14 digits. Update the message to clarify both constraints.\n\nFixes #344","fileTypesAndContributionMap":{"functional-code":{"insertions":3,"deletions":1}}},{"hash":"022f6a3852fc9710cb925dbb46301ae56e140694","isMergeCommit":true,"messageTitle":"Merge pull request #384 from p12010304/fix-find-sort-format","messageBody":"docs: Add command format for find and sort in UG","fileTypesAndContributionMap":{}},{"hash":"752c0eab8cce2447a3b10767ce290ba8ff55ad21","isMergeCommit":true,"messageTitle":"Merge pull request #387 from p12010304/fix-similar-contact-docs","messageBody":"docs: Document limitations of similar-name detection","fileTypesAndContributionMap":{}},{"hash":"b7864bfef5ea7d0e71a34b0bb8e50e559cf891cb","isMergeCommit":false,"messageTitle":"Document clearing fields via edit command in UG","messageBody":"The UG showed \u0027edit 2 n/Betsy Crower t/\u0027 as an example but did not\nexplain that providing a prefix with no value clears that field.\nAdd a note explaining this behavior with examples.\n\nFixes #327\n","fileTypesAndContributionMap":{"docs":{"insertions":2,"deletions":1}}},{"hash":"e14172245108eeae32664bc3af6897c349de55f1","isMergeCommit":false,"messageTitle":"Add manual testing instructions for more features in DG","messageBody":"The manual testing section only covered deleting contacts, launching,\nand saving data. Add test instructions for adding, editing, notes,\nfinding, and sorting contacts.\n\nFixes #363\n","fileTypesAndContributionMap":{"docs":{"insertions":69,"deletions":0}}},{"hash":"e2cf17962145ddc3375e9c9d03d1b45efccae6c7","isMergeCommit":true,"messageTitle":"Merge pull request #407 from p12010304/fix-ug-edit-clear-field","messageBody":"Document clearing fields via empty prefix in edit command","fileTypesAndContributionMap":{}},{"hash":"35d65ba86f19ea4f213d42e4422c567b6df46d1e","isMergeCommit":true,"messageTitle":"Merge pull request #408 from p12010304/fix-dg-manual-testing","messageBody":"Add manual testing instructions for more features in DG","fileTypesAndContributionMap":{}}]},{"date":"2026-04-13T00:00:00","commitResults":[{"hash":"5cbde755600ea4ea79cab0125bb0d51f7f6a2d0f","isMergeCommit":true,"messageTitle":"Merge pull request #398 from p12010304/fix-view-files-placeholder","messageBody":"Remove \u0027Image to be added\u0027 placeholder in view files section","fileTypesAndContributionMap":{}}]}]},"authorFileTypeContributionMap":{"JustATin555":{"docs":23,"functional-code":2,"test-code":0},"Cxyu629":{"docs":0,"functional-code":53,"test-code":3},"allisonllx":{"docs":12,"functional-code":17,"test-code":28},"deltaMinor":{"docs":215,"functional-code":79,"test-code":51},"p12010304":{"docs":91,"functional-code":39,"test-code":16}},"authorContributionVariance":{"JustATin555":576.0,"Cxyu629":940.4444,"allisonllx":608.4444,"deltaMinor":40938.777,"p1201030