ions":0}}},{"hash":"219f7c7ebbbe4e18c96effadbcfe73bf5e727456","isMergeCommit":true,"messageTitle":"Merge pull request #305 from ojunyi/branch-add-final-enhancement","messageBody":"Branch add final enhancement","fileTypesAndContributionMap":{}}]}],"tehmiw":[{"date":"2026-04-14T00:00:00","commitResults":[{"hash":"beb461cfe08a69bb0f12485df5debccece36ee80","isMergeCommit":false,"messageTitle":"Amend prefix message for tag","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":1,"deletions":1}}},{"hash":"331625e9d12f27118ee6c13354cee862183e7620","isMergeCommit":false,"messageTitle":"Update diagram","messageBody":"","fileTypesAndContributionMap":{"docs":{"insertions":24,"deletions":25}}}]}],"ZhangQixiang123":[{"date":"2026-04-11T00:00:00","commitResults":[{"hash":"12b41ed068281c6dda14b05a6bbaad3b308ed636","isMergeCommit":false,"messageTitle":"fix: resolve delete student against filtered list (#246)","messageBody":"After running find inside a selected tutorial, DeleteCommand was still\nindexing into currentTutorial.getStudents() (the unfiltered list), which\ndid not match the indices the user saw in the UI. This could silently\ndelete the wrong student.\n\nResolve the target from model.getFilteredStudentList() instead, so the\ndisplayed index maps to the displayed student. Still verify membership\nin the current tutorial before removing.\n","fileTypesAndContributionMap":{"functional-code":{"insertions":3,"deletions":3},"test-code":{"insertions":36,"deletions":0}}},{"hash":"c6d34ec0f79d2648b87e19615647c8b0062670d7","isMergeCommit":false,"messageTitle":"fix: reject tutorials that overlap an existing tutorial (#271, #248)","messageBody":"The app models a single tutor\u0027s schedule, so two tutorials can never\nrun at the same time. There was no such check: AddCommand accepted any\nnew tutorial as long as its code was unique, which both let a tutor\ndouble-book themselves (#248) and made it possible for the same\nstudent to end up in overlapping tutorials (#271).\n\nAdd a pair of pure helpers on the value objects:\n- TimeSlot.overlapsWith compares parsed start/end times; touching\n  boundaries (10:00-11:00 vs 11:00-12:00) are NOT treated as overlap.\n- Tutorial.overlapsWith returns true only when the day matches AND\n  time slots overlap; a tutorial never overlaps with itself.\n\nWire this into AddCommand\u0027s tutorial branch: before accepting a new\ntutorial, scan the full tutorial list and reject with a message that\nnames the conflicting tutorial code. Cover the two typical cases in\nAddCommandIntegrationTest (strict overlap rejected, back-to-back slot\nallowed).\n","fileTypesAndContributionMap":{"functional-code":{"insertions":46,"deletions":0},"test-code":{"insertions":42,"deletions":0}}},{"hash":"653b10c71f37691d1390d8a8b7cfd1af7331791c","isMergeCommit":false,"messageTitle":"fix: require selected tutorial for edit command (#256)","messageBody":"AddCommand and DeleteCommand both refuse to operate on a student when\nno tutorial is selected, but EditCommand silently ran against the\nglobal student list. This was inconsistent and let users mutate\nrecords they could not see in the current view.\n\nAdd the same MESSAGE_NO_CURRENT_OPERATING_TUTORIAL guard to\nEditCommand so all three student-mutating commands behave the same.\n\nRefactor EditCommandTest to set a current operating tutorial in\n@BeforeEach via a small helper, and add a simulateEdit helper that\nmirrors what EditCommand mutates so expectedModel matches actualModel\nunder the new tutorial-scoped filter. New test exercises the\nno-tutorial-selected failure path.\n","fileTypesAndContributionMap":{"functional-code":{"insertions":7,"deletions":0},"test-code":{"insertions":40,"deletions":5}}}]},{"date":"2026-04-12T00:00:00","commitResults":[{"hash":"3b3f9a5dafc74bb79fe7f6aeafe485b8e4bc2658","isMergeCommit":false,"messageTitle":"fix: surface invalid-index error for delete command (#227, #228)","messageBody":"DeleteCommandParser previously rewrapped all ParseExceptions with\nMESSAGE_INVALID_COMMAND_FORMAT, masking the invalid-index message\nfrom ParserUtil.parseIndex when index was 0 or negative.\n\nCo-Authored-By: Claude Opus 4.6 (1M context) \u003cnoreply@anthropic.com\u003e\n","fileTypesAndContributionMap":{"functional-code":{"insertions":15,"deletions":21},"test-code":{"insertions":11,"deletions":0}}}]},{"date":"2026-04-14T00:00:00","commitResults":[{"hash":"1f42ffb348e0c93128f8e4f4d2f4c687d59206ae","isMergeCommit":true,"messageTitle":"Merge pull request #303 from tehmiw/update-diagrams","messageBody":"Update diagram","fileTypesAndContributionMap":{}}]}],"jyc300564":[{"date":"2026-04-11T00:00:00","commitResults":[{"hash":"667d14d7d9fbebd0464ffa7446ae5103b7464070","isMergeCommit":false,"messageTitle":"Remove validation check for matric numbers","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":5,"deletions":4},"docs":{"insertions":3,"deletions":3},"test-code":{"insertions":3,"deletions":3}}},{"hash":"8ac1670fa50136bb6498064222a69e6ec00db4e3","isMergeCommit":true,"messageTitle":"Merge pull request #282 from gaoze24/delete-ppp","messageBody":"update project portfolio page","fileTypesAndContributionMap":{}}]},{"date":"2026-04-12T00:00:00","commitResults":[{"hash":"6ddb112ca923db39d8b5ac52b56cdcb38f3dff86","isMergeCommit":true,"messageTitle":"Merge branch \u0027master\u0027 of https://github.com/AY2526S2-CS2103T-W13-4/tp into remove-matric-validation-check","messageBody":"","fileTypesAndContributionMap":{}},{"hash":"b041ae13f5da5c9a253513fc32481594993f619f","isMergeCommit":false,"messageTitle":"Relax constraints for valid names","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":9,"deletions":9},"docs":{"insertions":1,"deletions":1},"test-code":{"insertions":6,"deletions":8}}}]},{"date":"2026-04-13T00:00:00","commitResults":[{"hash":"32187d2c3cf0a8a8d628a871cdec2c6a37a54808","isMergeCommit":false,"messageTitle":"Change matric number to be case-insensitive","messageBody":"","fileTypesAndContributionMap":{"functional-code":{"insertions":2,"deletions":2}}}]}],"gaoze24":[{"date":"2026-04-11T00:00:00","commitResults":[{"hash":"52116913392c3d29cb922efd5529575324b491e6","isMergeCommit":false,"messageTitle":"update project portfolio page","messageBody":"","fileTypesAndContributionMap":{"docs":{"insertions":2,"deletions":47}}}]},{"date":"2026-04-13T00:00:00","commitResults":[{"hash":"f32937d3a5344aa265339550a85d918ed483fb8f","isMergeCommit":false,"messageTitle":"docs: make Developer Guide NFRs measurable","messageBody":"Clarify ambiguous NFR wording by replacing subjective terms with testable criteria.\n\nDefine command performance expectations for up to 1000 students and 100 tutorial slots.\nReplace work well with explicit UI acceptance criteria at stated resolutions and scaling: no overlap, no truncated text, and no horizontal scrolling needed to access controls.\n","fileTypesAndContributionMap":{"docs":{"insertions":2,"deletions":2}}},{"hash":"8efb7d54d605485b08b8f41ed88695bbbf264866","isMergeCommit":false,"messageTitle":"fix(edit): correct usage message prefix-value spacing","messageBody":"Update EditCommand usage text to avoid implying that prefixes and values are contiguous.\nThe error/help format now shows:\nedit INDEX [/name NAME] [/phone PHONE NUMBER] [/email EMAIL] [/matric MATRICNUMBER] [/tag TAG]...\nAlso update the example command to include spaces after /phone and /email.\n","fileTypesAndContributionMap":{"functional-code":{"insertions":7,"deletions":7}}},{"hash":"bb3fd6a375ce21d0561715bb28e6b3525f5e3d6f","isMergeCommit":false,"messageTitle":"docs(ug): clarify add-student duplicate matching criterion","messageBody":"Update the User Guide to state that existing students are matched by matric number when adding to a tutorial, instead of “name or matric number”, so the documentation matches actual application behavior.\n","fileTypesAndContributionMap":{"docs":{"insertions":1,"deletions":1}}}]}]},"authorFileTypeContributionMap":{"ojunyi":{"docs":355,"functional-code":54,"test-code":5,"other":1},"tehmiw":{"docs":21,"functional-code":0,"test-code":0},"ZhangQixiang123":{"docs":0,"functional-code":56,"test-code":129},"jyc300564":{"docs":2,"functional-code":16,"test-code":9},"gaoze24":{"docs":5,"functional-code":1,"test-code":0}},"authorContributionVariance":{"ojunyi":26082.25,"tehmiw":162.5625,"ZhangQixiang123":3277.5625,"jyc300564":217.5625,"gaoze24":297.5625},"authorDisplayNameMap":{"ojunyi":"CS2103T-W13-4 ONG ..N YI","tehmiw":"CS2103T-W13-4 TEH .. WEI","ZhangQixiang123":"CS2103T-W13-4 ZHAN..IANG","jyc300564":"CS2103T-W13-4 JIN ..DONG","gaoze24":"CS2103T-W13-4 GAO ..O ZE"}}
